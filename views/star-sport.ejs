<script src="https://cdn.tailwindcss.com"></script>
<script src="https://cdn.jsdelivr.net/npm/shaka-player@4.16.2/dist/shaka-player.ui.min.js"></script>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/shaka-player@4.16.2/dist/controls.css"/>

<style>

.shaka-controls-container{
opacity:0;
transition:opacity .3s;
background:linear-gradient(transparent,rgba(0,0,0,.6)) !important;
}

#container:hover .shaka-controls-container{
opacity:1;
}

.shaka-seek-bar-container{
height:6px !important;
}

.shaka-played{
background:#ff0000 !important;
}

.shaka-buffered{
background:#0066ff !important;
}

/* video{
filter:brightness(1.15) contrast(1.15) saturate(1.2);
} */

</style>

<script>

/* =========================
ANTI EMBED PROTECTION
========================= */

if (window.self !== window.top) {

document.body.innerHTML = `
<div style="
position:fixed;
inset:0;
display:flex;
align-items:center;
justify-content:center;
background:#000;
color:white;
font-size:22px;
font-weight:bold;">
Embedding not allowed
</div>
`;

throw new Error("Embed blocked")

}

document.addEventListener("contextmenu",e=>e.preventDefault())

const CONFIG={
streamUrl:"<%= streamUrl %>",
keyId:"<%= keyId %>",
key:"<%= key %>",
cookieUrl:"<%= cookieUrl %>"
}

document.addEventListener("DOMContentLoaded",async()=>{

shaka.polyfill.installAll()

if(!shaka.Player.isBrowserSupported()){
alert("Browser not supported")
return
}

const video=document.getElementById("video")
const player=new shaka.Player(video)

/* PLAYER CONFIG */

player.configure({

streaming:{
bufferingGoal:30,
rebufferingGoal:5,
bufferBehind:60,
lowLatencyMode:false,

retryParameters:{
maxAttempts:10,
baseDelay:1000,
backoffFactor:2,
timeout:30000
}
},

abr:{
enabled:true,
defaultBandwidthEstimate:2500000,
switchInterval:4,
bandwidthUpgradeTarget:0.75,
bandwidthDowngradeTarget:0.90
},

drm:{
clearKeys:{
[CONFIG.keyId]:CONFIG.key
}
}

})

/* PLAYER UI */

const ui=new shaka.ui.Overlay(
player,
document.getElementById("container"),
video
)

ui.configure({
addBigPlayButton:true,
controlPanelElements:[
"play_pause",
"time_and_duration",
"spacer",
"mute",
"volume",
"quality",
"playback_rate",
"picture_in_picture",
"fullscreen"
]
})

/* COOKIE SYSTEM */

let cookieValue=""

async function loadCookie(){
try{
const res=await fetch(CONFIG.cookieUrl,{cache:"no-store"})
const data=await res.json()
cookieValue=data.cookie || ""
}catch(e){
console.log("cookie error")
}
}

await loadCookie()
setInterval(loadCookie,300000)

/* REQUEST HEADERS */

player.getNetworkingEngine().registerRequestFilter((type,request)=>{

request.headers["Referer"]="https://www.jiotv.com/"
request.headers["User-Agent"]="plaYtv/7.1.5 (Linux;Android 13)"

if(cookieValue){

request.headers["Cookie"]=cookieValue

let urlCookie=cookieValue.startsWith("__hdnea__=")
?cookieValue.substring(10)
:cookieValue

if(
(type===shaka.net.NetworkingEngine.RequestType.MANIFEST ||
type===shaka.net.NetworkingEngine.RequestType.SEGMENT)
&&
!request.uris[0].includes("__hdnea__")
){

const sep=request.uris[0].includes("?")?"&":"?"

request.uris[0]+=sep+"__hdnea__="+urlCookie

}

}

})

/* AUTO STREAM RECOVERY */

let retryInterval=null
let isLoading=false

async function startStream(){

if(isLoading) return
isLoading=true

try{

console.log("Trying to start stream...")

if(player){
await player.unload()
}

await player.load(CONFIG.streamUrl)

console.log("Stream started successfully")

if(retryInterval){
clearInterval(retryInterval)
retryInterval=null
}

}catch(e){

console.log("Stream offline, retrying...")

if(!retryInterval){

retryInterval=setInterval(async()=>{

try{

console.log("Retrying stream...")

if(player){
await player.unload()
}

await player.load(CONFIG.streamUrl)

console.log("Stream started!")

clearInterval(retryInterval)
retryInterval=null

}catch(err){

console.log("Still offline...")

}

},5000)

}

}

isLoading=false

}

player.addEventListener("error",()=>{
startStream()
})

startStream()

})

</script>
<!-- Inspect Devtools Disble -->
<script>

/* =========================
RIGHT CLICK BLOCK
========================= */

document.addEventListener("contextmenu", function(e){
  e.preventDefault();
});


/* =========================
KEYBOARD SHORTCUT BLOCK
========================= */

document.addEventListener("keydown", function(e){

  const key = e.key.toLowerCase();

  // F12
  if(e.key === "F12"){
    e.preventDefault();
  }

  // Ctrl+U
  if(e.ctrlKey && key === "u"){
    e.preventDefault();
  }

  // Ctrl+Shift+I
  if(e.ctrlKey && e.shiftKey && key === "i"){
    e.preventDefault();
  }

  // Ctrl+Shift+J
  if(e.ctrlKey && e.shiftKey && key === "j"){
    e.preventDefault();
  }

  // Ctrl+Shift+C
  if(e.ctrlKey && e.shiftKey && key === "c"){
    e.preventDefault();
  }

});

/* =========================
DEVTOOLS DETECT + REDIRECT
========================= */

(function(){

const REDIRECT_URL = "https://sixstorm-live.onrender.com/developer_tools_warning";

let devtoolsOpen = false;

/* size detection */

setInterval(function(){

const width = window.outerWidth - window.innerWidth > 160;
const height = window.outerHeight - window.innerHeight > 160;

if(width || height){

triggerRedirect();

}

},2000);


/* debugger timing detection */

setInterval(function(){

const start = new Date().getTime();

debugger;

const end = new Date().getTime();

if(end - start > 100){

triggerRedirect();

}

},2000);


/* redirect function */

function triggerRedirect(){

if(devtoolsOpen) return;

devtoolsOpen = true;

document.body.innerHTML = `
<div style="
height:100vh;
display:flex;
align-items:center;
justify-content:center;
background:black;
color:white;
font-size:24px;
font-weight:bold;">
⚠ Developer Tools Detected
</div>
`;

setTimeout(()=>{

window.location.replace(REDIRECT_URL);

},800);

}

})();




/* =========================
DEBUGGER TRAP
========================= */

(function(){
  function trap(){
    debugger;
    setTimeout(trap,2000);
  }
  trap();
})();


/* =========================
CONSOLE BLOCK
========================= */

console.log = function(){};
console.warn = function(){};
console.error = function(){};

</script>



<!-- Denied Direct Player Streaming -->

