<%- include("partials/header") %>

<body class="bg-gradient-to-r from-gray-900 via-gray-800 to-gray-900 min-h-screen flex flex-col">

<!-- NAVBAR -->

<nav class="bg-[#020617]/80 backdrop-blur-xl border-b border-white/10 sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">

    <a href="/" class="text-2xl md:text-3xl font-bold">
      <span class="bg-gradient-to-r from-yellow-400 to-orange-400 bg-clip-text text-transparent">Six</span>
      <span class="text-white">Storm</span>
    </a>

    <button id="menuBtn" class="md:hidden text-white text-2xl">☰</button>

    <div id="menu"
      class="hidden md:flex md:items-center md:space-x-6 absolute md:static top-16 left-0 w-full md:w-auto bg-[#020617] md:bg-transparent text-center">

      <a href="/" class="block py-3 md:py-0 text-gray-300 hover:text-yellow-400">Home</a>
      <a href="/contact-us" class="block py-3 md:py-0 text-gray-300 hover:text-yellow-400">Contact</a>

    </div>
  </div>
</nav>

<!-- MAIN CONTENT -->

<main class="flex-grow px-4 py-10">

  <div class="max-w-3xl mx-auto bg-gray-900/60 backdrop-blur-md border border-white/10 rounded-2xl shadow-xl p-6 md:p-10">

    <h1 class="text-3xl md:text-4xl font-bold text-center mb-8 text-yellow-400">
      About SixStorm
    </h1>

    <p class="text-gray-300 leading-relaxed mb-6">
      <span class="font-semibold text-white">SixStorm</span> is a cricket information
      platform created for cricket fans who want quick and easy access to match updates,
      schedules, and tournament information.
    </p>

    <p class="text-gray-300 leading-relaxed mb-6">
      Our goal is to provide accurate and fast cricket related information including
      match schedules, team details, tournament updates, and important cricket news
      from around the world.
    </p>

    <p class="text-gray-300 leading-relaxed mb-6">
      SixStorm is designed to be simple, fast, and mobile-friendly so cricket lovers
      can easily stay updated with their favorite teams and tournaments anytime.
    </p>

    <p class="text-gray-300 leading-relaxed">
      This platform is developed and maintained by
      <span class="text-yellow-400 font-semibold">Naveen Rathore</span>.
    </p>

  </div>

</main>

<!-- FOOTER -->

<%- include("partials/footer") %>

<script>
const btn = document.getElementById("menuBtn");
const menu = document.getElementById("menu");

btn.addEventListener("click", () => {
  menu.classList.toggle("hidden");
});
</script>

</body>
</html>