<!DOCTYPE html>
<html>
  <head>
    <title>SixStorm-live</title>

    <link rel="icon" type="image/png" href="/images/favicon.png" />

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="google-site-verification"
      content="RQDDLZXyk8LLoNq02uDwhfcGWUhNYj4kGHlJc9W5ib0"
    />

    <meta
      name="description"
      content="SixStorm provides live cricket streaming access, match updates, and sports coverage from publicly available sources."
    />

    <meta
      name="keywords"
      content="cricket live, cricket streaming, live cricket match, IPL live, cricket watch online"
    />

    <meta name="author" content="Naveen Rathore" />

    <meta property="og:title" content="SixStorm Live Cricket Streaming" />
    <meta
      property="og:description"
      content="Watch live cricket matches and stay updated with match coverage."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://sixstorm.onrender.com" />
    <meta
      property="og:image"
      content="https://sixstorm.onrender.com/images/favicon.png"
    />

    <meta name="robots" content="index, follow" />

    <script src="https://cdn.tailwindcss.com"></script>
  </head>

  <body
    class="bg-gradient-to-br from-[#0f172a] via-[#020617] to-[#111827] min-h-screen flex flex-col text-white"
  >
    <!-- NAVBAR -->

    <nav
      class="bg-[#020617]/80 backdrop-blur-xl border-b border-white/10 sticky top-0 z-50 shadow-xl"
    >
      <div
        class="max-w-7xl mx-auto px-4 py-3 flex justify-between items-center"
      >
        <a href="/" class="text-xl md:text-3xl font-bold">
          <span
            class="bg-gradient-to-r from-yellow-400 to-orange-400 bg-clip-text text-transparent"
            >Six</span
          >
          <span class="text-white">Storm</span>
        </a>

        <div class="flex gap-3 md:gap-6 text-xs md:text-base font-semibold">
          <a href="/help" class="hover:text-red-400 transition">Help</a>

          <a href="/legal" class="hover:text-red-400 transition">Disclaimer</a>

          <a href="/privacy-policy" class="hover:text-red-400 transition"
            >Privacy</a
          >

          <a href="/contact-us" class="hover:text-red-400 transition"
            >Contact</a
          >
        </div>
      </div>
    </nav>

    <!-- MAIN -->

    <div class="flex-grow max-w-7xl mx-auto px-4 py-8 space-y-10">
      <!-- SLIDER -->

      <div
        class="relative w-full max-w-6xl mx-auto aspect-video overflow-hidden rounded-3xl shadow-2xl border border-white/20"
      >
        <img
          id="slider"
          class="w-full h-full object-cover transition duration-700"
        />

        <div
          class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"
        ></div>

        <div class="absolute bottom-6 left-6 md:bottom-10 md:left-10 max-w-xl">
          <h2
            id="slideTitle"
            class="text-lg md:text-3xl font-bold text-white"
          ></h2>

          <p id="slideDesc" class="text-xs md:text-lg text-gray-300 mt-2"></p>
        </div>

        <div
          id="dots"
          class="absolute bottom-4 w-full flex justify-center gap-3"
        ></div>
      </div>

      <!-- PAGE HEADING -->

      <div class="text-center space-y-4">
        <h1 class="text-3xl md:text-6xl font-extrabold tracking-wide">
          <span class="text-yellow-400">CRICKET</span>
          <span class="text-white">HUB</span>
        </h1>

        <h2 class="text-sm md:text-2xl text-gray-300 font-semibold">
          IPL • ICC T20 World Cup • Match Updates & Viewing Access
        </h2>
      </div>

      <!-- MATCH CARD -->

      <div class="flex justify-center mt-6">
        <div
          class="w-full max-w-md bg-gradient-to-br from-[#1e293b] via-[#020617] to-[#111827] p-[2px] rounded-3xl shadow-2xl"
        >
          <div
            class="bg-[#020617] rounded-3xl p-6 text-center space-y-6 border border-white/10"
          >
            <p class="text-red-400 font-semibold animate-pulse">
              🔴 Upcoming Live Match
            </p>

            <h2
              class="text-xl md:text-2xl font-bold text-yellow-400 tracking-wide"
            >
              IPL 2026 Match-6
            </h2>

            <div class="flex justify-center items-center gap-8">
              <div class="flex flex-col items-center gap-2">
                <img
                  src="https://upload.wikimedia.org/wikipedia/en/thumb/4/4c/Kolkata_Knight_Riders_Logo.svg/250px-Kolkata_Knight_Riders_Logo.svg.png"
                  class="w-14 h-14 object-contain"
                />

                <span class="text-lg font-bold">KKR</span>
              </div>

              <div
                class="px-4 py-2 rounded-full bg-red-600 text-white font-bold shadow-lg"
              >
                VS
              </div>

              <div class="flex flex-col items-center gap-2">
                <img
                  src="https://upload.wikimedia.org/wikipedia/en/thumb/5/51/Sunrisers_Hyderabad_Logo.svg/250px-Sunrisers_Hyderabad_Logo.svg.png"
                  class="w-14 h-14 object-contain"
                />

                <span class="text-lg font-bold">SRH</span>
              </div>
            </div>

            <div class="text-gray-300 text-sm leading-relaxed">
              📅 <span class="text-white font-semibold">2 April 2026</span>
              <br />

              🏟
              <span class="text-white font-semibold"
                >Eden Gardens, Kolkata</span
              >
            </div>

            <div
              id="countdown1"
              class="text-2xl font-mono text-yellow-400 bg-black/50 py-3 rounded-lg border border-yellow-400/20"
            ></div>
          </div>
        </div>
      </div>

      <!-- WATCH BUTTON -->

      <div class="flex flex-col items-center gap-6">
        <a href="/star_sport_1_live_HD_ipl">
          <button
            class="w-[260px] py-3 text-lg rounded-full font-bold text-white bg-gradient-to-r from-[#0047AB] via-[#1E90FF] to-[#00BFFF] hover:scale-110 transition duration-300 shadow-xl"
          >
            ▶ Watch Live
          </button>
        </a>
      </div>
    </div>

    <!-- FOOTER -->

    <footer
      class="bg-[#020617]/80 border-t border-white/10 text-center py-5 text-sm text-gray-300"
    >
      © 2026
      <span class="font-bold">
        <span
          class="bg-gradient-to-r from-yellow-400 to-orange-400 bg-clip-text text-transparent"
        >
          Six
        </span>

        <span class="text-white">Storm</span>
      </span>

      • Developed by Naveen Rathore
    </footer>

    <script>
      const slides = [
        {
          img: "https://img10.hotstar.com/image/upload/f_auto,q_90,w_1920/sources/r1/cms/prod/381/1774935130381-i",
          title: "SRH vs KKR",
          desc: "Kolkata Face Hyderabad in the TATA IPL 2026",
        },

        {
          img: "https://img10.hotstar.com/image/upload/f_auto,q_90,w_1920/sources/r1/cms/prod/5753/1774882555753-i",
          title: "TATA IPL 2026 ",
          desc: "Watch the Biggest Cricket League – IPL ",
        },
        {
          img: "https://img10.hotstar.com/image/upload/f_auto,q_90,w_1920/sources/r1/cms/prod/6372/1774719566372-i",
          title: "RCB Ready for Second Title",
          desc: "Can the king’s soldiers lift another IPL trophy this season?",
        },
        {
          img: "https://img10.hotstar.com/image/upload/f_auto,q_90,w_1920/sources/r1/cms/prod/3980/1767461013980-i",
          title: "CSK Eye for 6th Title",
          desc: "CSK's new era will be able to win its 6th trophy",
        },
        {
          img: "https://img10.hotstar.com/image/upload/f_auto,q_90,w_1920/sources/r1/cms/prod/1535/1774804471535-i",
          title: "Mumbai Chase the highest Score!",
          desc: "Pandya's Paltan!",
        },
        {
          img: "https://img10.hotstar.com/image/upload/f_auto,q_90,w_1920/sources/r1/cms/prod/2526/1772995532526-i",
          title: "India Winning Moment",
          desc: "Team India Lifts Their Third T20 World Cup Trophy!",
        },
      ];

      let index = 0;

      const slider = document.getElementById("slider");
      const title = document.getElementById("slideTitle");
      const desc = document.getElementById("slideDesc");

      const dots = document.getElementById("dots");

      slides.forEach((_, i) => {
        const dot = document.createElement("div");

        dot.className =
          "w-3 h-3 bg-white/40 rounded-full cursor-pointer hover:bg-white";

        dot.onclick = () => {
          index = i;
          showSlide();
        };

        dots.appendChild(dot);
      });

      function showSlide() {
        slider.src = slides[index].img;
        title.innerText = slides[index].title;
        desc.innerText = slides[index].desc;

        document.querySelectorAll("#dots div").forEach((dot, i) => {
          dot.classList.remove("bg-white");
          if (i === index) dot.classList.add("bg-white");
        });
      }
      function nextSlide() {
        index = (index + 1) % slides.length;
        showSlide();
      }

      setInterval(nextSlide, 4000);

      showSlide();
      function toggleMenu() {
        const menu = document.getElementById("mobileMenu");

        if (menu.classList.contains("-right-[260px]")) {
          menu.classList.remove("-right-[260px]");
          menu.classList.add("right-0");
        } else {
          menu.classList.remove("right-0");
          menu.classList.add("-right-[260px]");
        }
      }

      // MATCH COUNTDOWN

      const matchDate = new Date("April 2, 2026 19:30:00").getTime();

      const countdown = setInterval(function () {
        const now = new Date().getTime();

        const distance = matchDate - now;

        const days = Math.floor(distance / (1000 * 60 * 60 * 24));
        const hours = Math.floor(
          (distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60),
        );
        const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((distance % (1000 * 60)) / 1000);

        document.getElementById("countdown1").innerHTML =
          days + "d " + hours + "h " + minutes + "m " + seconds + "s";

        if (distance < 0) {
          clearInterval(countdown);

          document.getElementById("countdown1").innerHTML = `
          <div class="flex justify-center ">
        <span class="bg-red-600 px-5 py-1 rounded-full text-xs sm:text-sm font-bold animate-pulse">
          LIVE
        </span>
      </div>
          `;
        }
      }, 1000);
    </script>
  </body>
</html>
