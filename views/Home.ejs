<%- include("partials/header") %>

  <body
    class="bg-gradient-to-br from-[#0f172a] via-[#020617] to-[#111827] min-h-screen flex flex-col text-white"
  >
    <!-- NAVBAR -->

    <!-- NAVBAR -->
<nav class="bg-[#020617]/80 backdrop-blur-xl border-b border-white/10 sticky top-0 z-50 shadow-xl">
  <div class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between">

    <!-- Logo Left -->
    <a href="/" class="text-2xl md:text-3xl font-bold flex-shrink-0 flex items-center gap-1">
      <span class="bg-gradient-to-r from-yellow-400 to-orange-400 bg-clip-text text-transparent">Six</span>
      <span class="text-white">Storm</span>
    </a>

    <!-- Navigation Links Right -->
    <div class="flex gap-4 md:gap-8 text-xs md:text-base font-semibold">
      <a href="/help" class="hover:text-red-400 transition">Help</a>
      <a href="/legal" class="hover:text-red-400 transition">Legal</a>
      <a href="/about-us" class="hover:text-red-400 transition">About</a>
      <a href="/points" class="hover:text-red-400 transition">Points</a>
      <a href="/contact-us" class="hover:text-red-400 transition">Contact</a>
    </div>

  </div>
</nav>
    <!-- MAIN -->

    <div class="flex-grow max-w-7xl mx-auto px-4 py-8 space-y-10">
      <!-- SLIDER -->

      <div
        class="relative w-full max-w-6xl mx-auto aspect-video overflow-hidden rounded-3xl shadow-2xl border border-white/20"
      >
        <img
          id="slider"
          class="w-full h-full object-cover transition duration-700"
        />

        <div
          class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"
        ></div>

        <div class="absolute bottom-6 left-6 md:bottom-10 md:left-10 max-w-xl">
          <h2
            id="slideTitle"
            class="text-lg md:text-3xl font-bold text-white"
          ></h2>

          <p id="slideDesc" class="text-xs md:text-lg text-gray-300 mt-2"></p>
        </div>

        <div
          id="dots"
          class="absolute bottom-4 w-full flex justify-center gap-3"
        ></div>
      </div>

      <!-- PAGE HEADING -->

      <div class="text-center space-y-4">
        <h1 class="text-3xl md:text-6xl font-extrabold tracking-wide">
          <span class="text-yellow-400">CRICKET</span>
          <span class="text-white">HUB</span>
        </h1>

        <h2 class="text-sm md:text-2xl text-gray-300 font-semibold">
          IPL • ICC T20 World Cup • Match Updates & Viewing Access
        </h2>
      </div>

      <!-- MATCH CARD -->

       <% if(matches && matches.length > 0){ %>

<% matches.forEach(match => { %>

<div class="flex justify-center mt-6">
  <div
    class="w-full max-w-md bg-gradient-to-br from-[#1e293b] via-[#020617] to-[#111827] p-[2px] rounded-3xl shadow-2xl"
  >
    <div
      class="bg-[#020617] rounded-3xl p-6 text-center space-y-6 border border-white/10"
    >
      <p class="text-red-400 font-semibold animate-pulse">
        🔴 Upcoming Live Match
      </p>
<h2 class="text-xl md:text-2xl font-bold text-yellow-400 tracking-wide">
  IPL <%= match.matchDesc %>
</h2>

      <div class="flex justify-center items-center gap-8">
        <div class="flex flex-col items-center gap-2">
          <img
            src="<%= match.team1Img %>"
            class="w-14 h-14 object-contain"
          />

          <span class="text-lg font-bold"><%= match.team1 %></span>
        </div>

        <div
          class="px-4 py-2 rounded-full bg-red-600 text-white font-bold shadow-lg"
        >
          VS
        </div>

        <div class="flex flex-col items-center gap-2">
          <img
            src="<%= match.team2Img %>"
            class="w-14 h-14 object-contain"
          />

          <span class="text-lg font-bold"><%= match.team2 %></span>
        </div>
      </div>

      <div class="text-gray-300 text-sm leading-relaxed">
        📅 <span class="text-white font-semibold"><%= match.date %></span>
        <br />

        🏟
        <span class="text-white font-semibold">
          <%= match.venue %>, <%= match.city %>
        </span>
      </div>

  <div
  class="countdown text-2xl font-mono text-yellow-400 bg-black/50 py-3 rounded-lg border border-yellow-400/20"
  data-start="<%= match.startDate %>"
>
</div>
    </div>
  </div>
</div>

<% }) %>

<% } else { %>

<p class="text-center text-gray-400 mt-10">
No upcoming IPL matches available
</p>

<% } %>

      <!-- WATCH BUTTON -->

      <div class="flex flex-col items-center gap-6">
        <a href="/star_sport_1_live_HD_ipl">
          <button
            class="w-[260px] py-3 text-lg rounded-full font-bold text-white bg-gradient-to-r from-[#0047AB] via-[#1E90FF] to-[#00BFFF] hover:scale-110 transition duration-300 shadow-xl"
          >
            ▶ Watch Live
          </button>
        </a>
      </div>
      <!-- <div class="flex flex-col items-center gap-6">
        <a href="/starsport-2">
          <button
            class="w-[260px] py-3 text-lg rounded-full font-bold text-white bg-gradient-to-r from-[#0047AB] via-[#1E90FF] to-[#00BFFF] hover:scale-110 transition duration-300 shadow-xl"
          >
            ▶ Watch Live
          </button>
        </a>
      </div> -->
     
      <div class="flex flex-col items-center gap-6 ">
  <a href="/star-sport-1">
    <button
      class="w-[260px] py-3 text-lg rounded-full font-bold text-white bg-gradient-to-r from-red-600 via-red-500 to-red-700 hover:scale-110 transition duration-300 shadow-xl"
    >
      ▶ Star Sport 1 [English]
    </button>
  </a>
</div>

    </div>
    

    <!-- FOOTER -->

    <%- include("partials/footer") %>

    <script>
      const slides = [
        {
          img: "https://img10.hotstar.com/image/upload/f_auto,q_90,w_1920/sources/r1/cms/prod/1499/1776583921499-i",
          title: "GT vs MI",
          desc: "Gujarat Face Mumbai in the TATA IPL 2026",
        },
        //  {
        //   img: "https://img10.hotstar.com/image/upload/f_auto,q_90,w_1920/sources/r1/cms/prod/4730/1776490294730-i",
        //   title: "PBKS vs LSG",
        //   desc: "Punjab Face Lucknow in the TATA IPL 2026",
        // },

         {
          img: "https://img10.hotstar.com/image/upload/f_auto,q_90,w_1920/sources/r1/cms/prod/8580/1776522998580-i",
          title: "Last Over Drama!",
          desc: "15 Off 5! Miller Turns Hero for DC!",
        },
             
        {
          img: "https://img10.hotstar.com/image/upload/f_auto,q_90,w_1920/sources/r1/cms/prod/5753/1774882555753-i",
          title: "TATA IPL 2026 ",
          desc: "Watch the Biggest Cricket League – IPL ",
        },
        {
          img: "https://img10.hotstar.com/image/upload/f_auto,q_90,w_1920/sources/r1/cms/prod/6372/1774719566372-i",
          title: "RCB Ready for Second Title",
          desc: "Can the king’s soldiers lift another IPL trophy this season?",
        },
        {
          img: "https://img10.hotstar.com/image/upload/f_auto,q_90,w_1920/sources/r1/cms/prod/2251/1775906772251-i",
          title: "Abhishek's 28-ball 74 vs PBKS",
          desc: "Top knocks!",
        },
        {
          img: "https://img10.hotstar.com/image/upload/f_auto,q_90,w_1920/sources/r1/cms/prod/8776/1775331088776-i",
          title: "Rizvi Rises as DC Outclass MI!",
          desc: "Pandya's Paltan!",
        },
        {
          img: "https://img10.hotstar.com/image/upload/f_auto,q_90,w_1920/sources/r1/cms/prod/2526/1772995532526-i",
          title: "India Winning Moment",
          desc: "Team India Lifts Their Third T20 World Cup Trophy!",
        },
      ];

      let index = 0;

      const slider = document.getElementById("slider");
      const title = document.getElementById("slideTitle");
      const desc = document.getElementById("slideDesc");

      const dots = document.getElementById("dots");

      slides.forEach((_, i) => {
        const dot = document.createElement("div");

        dot.className =
          "w-3 h-3 bg-white/40 rounded-full cursor-pointer hover:bg-white";

        dot.onclick = () => {
          index = i;
          showSlide();
        };

        dots.appendChild(dot);
      });

      function showSlide() {
        slider.src = slides[index].img;
        title.innerText = slides[index].title;
        desc.innerText = slides[index].desc;

        document.querySelectorAll("#dots div").forEach((dot, i) => {
          dot.classList.remove("bg-white");
          if (i === index) dot.classList.add("bg-white");
        });
      }
      function nextSlide() {
        index = (index + 1) % slides.length;
        showSlide();
      }

      setInterval(nextSlide, 4000);

      showSlide();
      function toggleMenu() {
        const menu = document.getElementById("mobileMenu");

        if (menu.classList.contains("-right-[260px]")) {
          menu.classList.remove("-right-[260px]");
          menu.classList.add("right-0");
        } else {
          menu.classList.remove("right-0");
          menu.classList.add("-right-[260px]");
        }
      }

      // MATCH COUNTDOWN
const countdowns = document.querySelectorAll(".countdown");

countdowns.forEach((box) => {
  const startTime = Number(box.dataset.start);

  const timer = setInterval(() => {
    const now = new Date().getTime();
    const distance = startTime - now;

    if (distance <= 0) {
      clearInterval(timer);

      box.innerHTML = `
      <div class="flex justify-center">
        <span class="bg-red-600 px-5 py-1 rounded-full text-sm font-bold animate-pulse">
          🔴 LIVE
        </span>
      </div>`;
      return;
    }

    const hours = Math.floor(distance / (1000 * 60 * 60));
    const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
    const seconds = Math.floor((distance % (1000 * 60)) / 1000);

    box.innerHTML = `${hours}h ${minutes}m ${seconds}s`;
  }, 1000);
});
     
    </script>
  </body>
</html>
