<!doctype html>
<html lang="en">
  <head>
    <title>SixStorm | Star Sport 1</title>
    <link rel="icon" type="image/png" href="/images/favicon2.png" />
    <link rel="shortcut icon" href="/images/favicon2.png" />
    <meta
      name="viewport"
      content="width=device-width,initial-scale=1.0,maximum-scale=1.0,user-scalable=no"
    />
    <meta name="referrer" content="no-referrer" />

    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/plyr@3.7.8/dist/plyr.css"
    />
    <script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>
    <script src="https://cdn.jsdelivr.net/npm/plyr@3.7.8/dist/plyr.polyfilled.js"></script>

    <style>
      body {
        background-color: #000;
        margin: 0;
        overflow: hidden;
      }

      .video-container {
        position: relative;
        width: 100%;
        height: 100vh;
      }

      video {
        width: 100%;
        height: 100%;
        object-fit: contain;
      }

      /* 🔥 LOADER OVERLAY */
      .loader {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: black;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        z-index: 999;
        color: white;
        font-family: Arial;
      }

      .loader-text {
        margin-bottom: 20px;
        font-size: 18px;
      }

      .progress-bar {
        width: 60%;
        height: 6px;
        background: #333;
        border-radius: 10px;
        overflow: hidden;
      }

      .progress {
        height: 100%;
        width: 0%;
        background: #00ffcc;
        animation: loadAnim 60s linear forwards;
      }

      @keyframes loadAnim {
        from {
          width: 0%;
        }
        to {
          width: 100%;
        }
      }
    </style>
  </head>

  <body>
    <div class="video-container">
      <!-- 🔥 LOADER -->
      <div class="loader" id="loader">
        <div class="loader-text">
          The stream is loading. Please wait up to 1 minute for the best viewing
          experience.
        </div>
        <div class="progress-bar">
          <div class="progress"></div>
        </div>
      </div>

      <video
        autoplay
        playsinline
        muted
        id="player"
        controls
        preload="metadata"
      ></video>
    </div>

    <script>
      document.addEventListener("DOMContentLoaded", function () {
        const video = document.getElementById("player");
        const loader = document.getElementById("loader");

        const source =
          "https://tcfbrravdlgqrymqfcgu.supabase.co/functions/v1/stream-proxy?url=http://180.94.28.28:8097/STAR-SPORTS-1/index.m3u8";

        let player;

        function hideLoader() {
          loader.style.display = "none";
        }

        function setupPlayer(hls, qualities = []) {
          player = new Plyr(video);

          // 🔥 Hide loader when video plays
          video.addEventListener("playing", hideLoader);

          // Backup: hide after 60 sec anyway
          setTimeout(hideLoader, 60000);
        }

        if (Hls.isSupported()) {
          const hls = new Hls();

          hls.loadSource(source);
          hls.attachMedia(video);

          hls.on(Hls.Events.MANIFEST_PARSED, () => {
            video.play().catch(() => {});
            setupPlayer(hls);
          });

          hls.on(Hls.Events.ERROR, function (_, data) {
            if (data.fatal) {
              hls.startLoad();
            }
          });
        } else if (video.canPlayType("application/vnd.apple.mpegurl")) {
          video.src = source;
          video.addEventListener("loadedmetadata", () => {
            video.play().catch(() => {});
            setupPlayer(null);
          });
        }
      });
    </script>
  </body>
</html>
