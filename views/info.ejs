<!DOCTYPE html>
<html lang="en">
  <head>
    <link rel="icon" type="image/png" href="/images/favicon2.png" />
    <link rel="shortcut icon" href="/images/favicon2.png" />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="SixStorm provides live cricket streaming access, match updates, and sports coverage from publicly available sources."
    />

    <meta
      name="keywords"
      content="cricket live, cricket streaming, live cricket match, IPL live, cricket watch online"
    />

    <meta name="author" content="Naveen Rathore" />

    <meta property="og:title" content="SixStorm Live Cricket Streaming" />

    <meta
      property="og:description"
      content="Watch live cricket matches and stay updated with match coverage."
    />

    <meta property="og:type" content="website" />

    <meta property="og:url" content="https://sixstorm.onrender.com" />
    <meta
      property="og:image"
      content="https://sixstorm.onrender.com/images/favicon.png"
    />

    <meta name="robots" content="index, follow" />

    <title>Legal Disclaimer | SixStorm</title>

    <link rel="icon" type="image/png" href="/images/favicon2.png" />
    <script src="https://cdn.tailwindcss.com"></script>
  </head>

  <body
    class="bg-gradient-to-r from-gray-900 via-gray-800 to-gray-900 min-h-screen flex flex-col"
  >
    <!-- NAVBAR -->

    <nav
      class="bg-[#020617]/80 backdrop-blur-xl border-b border-white/10 sticky top-0 z-50"
    >
      <div
        class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center"
      >
        <!-- LOGO -->

        <a href="/" class="text-2xl md:text-3xl font-bold">
          <span
            class="bg-gradient-to-r from-yellow-400 to-orange-400 bg-clip-text text-transparent"
            >Six</span
          ><span class="text-white">Storm</span>
        </a>

        <!-- MOBILE BUTTON -->

        <button id="menuBtn" class="md:hidden text-white text-2xl">☰</button>

        <!-- MENU -->

        <div
          id="menu"
          class="hidden md:flex md:items-center md:space-x-6 absolute md:static top-16 left-0 w-full md:w-auto bg-[#020617] md:bg-transparent text-center"
        >
          <a
            href="/"
            class="block py-3 md:py-0 text-gray-300 hover:text-yellow-400"
            >Home</a
          >

          <a
            href="/contact"
            class="block py-3 md:py-0 text-gray-300 hover:text-yellow-400"
            >Contact</a
          >
        </div>
      </div>
    </nav>

    <!-- MAIN CONTENT -->

    <main class="flex-grow flex items-center justify-center p-4">
      <div
        class="max-w-3xl bg-gray-100 shadow-2xl rounded-2xl p-6 md:p-8 border-t-8 border-blue-600"
      >
        <h1
          class="text-2xl md:text-3xl font-bold text-blue-700 mb-6 text-center"
        >
          Legal Disclaimer
        </h1>

        <p class="text-gray-800 text-base md:text-lg mb-4 leading-relaxed">
          Welcome to <span class="font-semibold text-blue-600">SixStorm</span>.
          Our platform acts only as an aggregator for publicly available content
          from third-party websites. We do not host, store, or distribute
          copyrighted material.
        </p>

        <p class="text-gray-800 text-base md:text-lg mb-4 leading-relaxed">
          All streaming content available through this website comes from
          external sources. We do not control or own the rights to such content.
        </p>

        <p class="text-gray-800 text-base md:text-lg mb-4 leading-relaxed">
          All trademarks, logos, and media content belong to their respective
          owners.
        </p>

        <p class="text-gray-800 text-base md:text-lg mb-4 leading-relaxed">
          If you are a copyright owner and believe any content violates your
          rights, please contact us and we will review and remove the link if
          necessary.
        </p>
      </div>
    </main>

    <!-- FOOTER -->

    <footer
      class="bg-[#020617]/80 border-t border-white/10 text-center py-5 text-sm text-gray-300"
    >
      © 2026
      <span class="font-bold">
        <span
          class="bg-gradient-to-r from-yellow-400 to-orange-400 bg-clip-text text-transparent"
          >Six</span
        ><span class="text-white">Storm</span>
      </span>

      • Developed by Naveen Rathore
    </footer>

    <!-- MOBILE MENU SCRIPT -->

    <script>
      const btn = document.getElementById("menuBtn");
      const menu = document.getElementById("menu");

      btn.addEventListener("click", () => {
        menu.classList.toggle("hidden");
      });
    </script>
  </body>
</html>
