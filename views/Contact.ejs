<!DOCTYPE html>
<html lang="en">
  <head>
    <link rel="icon" type="image/png" href="/images/favicon.png" />
    <link rel="shortcut icon" href="/images/favicon.png" />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="SixStorm provides live cricket streaming access, match updates, and sports coverage from publicly available sources."
    />

    <meta
      name="keywords"
      content="cricket live, cricket streaming, live cricket match, IPL live, cricket watch online"
    />

    <meta name="author" content="Naveen Rathore" />

    <meta property="og:title" content="SixStorm Live Cricket Streaming" />

    <meta
      property="og:description"
      content="Watch live cricket matches and stay updated with match coverage."
    />

    <meta property="og:type" content="website" />

    <meta property="og:url" content="https://sixstorm.onrender.com" />
    <meta
      property="og:image"
      content="https://sixstorm.onrender.com/images/favicon.png"
    />

    <meta name="robots" content="index, follow" />

    <title>Contact-us| SixStorm</title>

    <link rel="icon" type="image/png" href="/images/favicon2.png" />
    <script src="https://cdn.tailwindcss.com"></script>
  </head>

  <body
    class="bg-gradient-to-r from-gray-900 via-gray-800 to-gray-900 min-h-screen flex flex-col"
  >
    <!-- NAVBAR -->

    <nav
      class="bg-[#020617]/80 backdrop-blur-xl border-b border-white/10 sticky top-0 z-50"
    >
      <div
        class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center"
      >
        <a href="/" class="text-2xl md:text-3xl font-bold">
          <span
            class="bg-gradient-to-r from-yellow-400 to-orange-400 bg-clip-text text-transparent"
            >Six</span
          ><span class="text-white">Storm</span>
        </a>

        <button id="menuBtn" class="md:hidden text-white text-2xl">☰</button>

        <div
          id="menu"
          class="hidden md:flex md:items-center md:space-x-6 absolute md:static top-16 left-0 w-full md:w-auto bg-[#020617] md:bg-transparent text-center"
        >
          <a
            href="/"
            class="block py-3 md:py-0 text-gray-300 hover:text-yellow-400"
            >Home</a
          >
          <a
            href="/privacy-policy"
            class="block py-3 md:py-0 text-gray-300 hover:text-yellow-400"
            >Privacy-Policy</a
          >
        </div>
      </div>
    </nav>

    <!-- MAIN CONTENT -->

    <main class="flex-grow px-4 py-10">
      <div class="max-w-xl mx-auto p-8 text-center">
        <h1 class="text-3xl font-bold text-yellow-400 mb-6">Contact Us</h1>

        <p class="text-gray-300 mb-6">
          If you have any questions, copyright concerns, or feedback, please
          contact us using the email below.
        </p>

        <div class="bg-gray-800 p-6 rounded-xl shadow-lg">
          <p class="text-lg font-semibold text-white">Email:</p>

          <p class="text-yellow-300 mt-2">support@cricpulselive.com</p>
        </div>
      </div>
    </main>

    <!-- FOOTER -->

    <footer
      class="bg-[#020617]/80 border-t border-white/10 text-center py-5 text-sm text-gray-300"
    >
      © 2026
      <span class="font-bold">
        <span
          class="bg-gradient-to-r from-yellow-400 to-orange-400 bg-clip-text text-transparent"
          >Six</span
        ><span class="text-white">Storm</span>
      </span>

      • Developed by Naveen Rathore
    </footer>

    <!-- MOBILE MENU SCRIPT -->

    <script>
      const btn = document.getElementById("menuBtn");
      const menu = document.getElementById("menu");

      btn.addEventListener("click", () => {
        menu.classList.toggle("hidden");
      });
    </script>
  </body>
</html>
