        overflow: hidden;
      }

      /* ── BG GRID ── */
      .bg-grid {
        position: fixed;
        inset: 0;
        background-image:
          linear-gradient(rgba(250, 204, 21, 0.025) 1px, transparent 1px),
          linear-gradient(90deg, rgba(250, 204, 21, 0.025) 1px, transparent 1px);
        background-size: 55px 55px;
        pointer-events: none;
        z-index: 0;
      }
      .orb {
        position: fixed;
        border-radius: 50%;
        filter: blur(100px);
        pointer-events: none;
        z-index: 0;
        animation: orbFloat 9s ease-in-out infinite;
      }
      .orb-1 {
        width: 420px;
        height: 420px;
        background: rgba(250, 204, 21, 0.05);
        top: -100px;
        left: -80px;
      }
      .orb-2 {
        width: 300px;
        height: 300px;
        background: rgba(239, 68, 68, 0.04);
        bottom: 60px;
        right: -60px;
        animation-delay: 4s;
      }
      @keyframes orbFloat {
        0%,
        100% {
          transform: translate(0, 0) scale(1);
        }
        50% {
          transform: translate(16px, -22px) scale(1.04);
        }
      }

      /* ── WRAPPER ── */
      .page-wrapper {
        position: fixed;
        inset: 0;
        display: flex;
        flex-direction: column;
        z-index: 1;
      }

      /* ── NAVBAR ── */
      .navbar {
        flex-shrink: 0;
        background: rgba(2, 6, 23, 0.9);
        backdrop-filter: blur(22px);
        border-bottom: 1px solid rgba(250, 204, 21, 0.1);
        z-index: 200;
      }
      .nav-inner {
        max-width: 1280px;
        margin: 0 auto;
        padding: 0 20px;
        height: 54px;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .nav-logo {
        text-decoration: none;
        display: flex;
        align-items: center;
      }
      .nav-logo-six {
        font-family: Arial, Helvetica, sans-serif;
        font-weight: 800;
        font-size: 1.75rem;
        letter-spacing: 2px;
        background: linear-gradient(135deg, #facc15, #f97316);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }
      .nav-logo-storm {
        font-family: Arial, Helvetica, sans-serif;
        font-weight: 800;
        font-size: 1.75rem;
        letter-spacing: 2px;
        color: #fff;
      }
      .nav-right {
        display: flex;
        align-items: center;
        gap: 16px;
      }
      .nav-badge {
        display: flex;
        align-items: center;
        gap: 6px;
        background: rgba(239, 68, 68, 0.1);
        border: 1px solid rgba(239, 68, 68, 0.3);
        color: #f87171;
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 2px;
        text-transform: uppercase;
        padding: 4px 12px;
        border-radius: 100px;
        animation: pulseBadge 2s ease-in-out infinite;
      }
      .nav-badge-dot {
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: #f87171;
        flex-shrink: 0;
      }
      @keyframes pulseBadge {
        0%,
        100% {
          opacity: 1;
          box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.3);
        }
        50% {
          opacity: 0.8;
          box-shadow: 0 0 0 5px rgba(239, 68, 68, 0);
        }
      }
      .nav-channel {
        font-size: 0.78rem;
        font-weight: 600;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.45);
      }

      /* ── STREAM BANNER ── */
      #streamBanner {
        flex-shrink: 0;
        background: linear-gradient(
          90deg,
          rgba(250, 204, 21, 0.08),
          rgba(250, 204, 21, 0.04),
          rgba(250, 204, 21, 0.08)
        );
        border-bottom: 1px solid rgba(250, 204, 21, 0.14);
        padding: 10px 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 14px;
        animation: bannerFadeIn 0.6s ease;
        position: relative;
        overflow: hidden;
      }
      #streamBanner::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(
          90deg,
          transparent,
          rgba(250, 204, 21, 0.04),
          transparent
        );
        animation: shimmer 3s linear infinite;
      }
      @keyframes shimmer {
        0% {
          transform: translateX(-100%);
        }
        100% {
          transform: translateX(100%);
        }
      }
      @keyframes bannerFadeIn {
        from {
          opacity: 0;
          transform: translateY(-10px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      .banner-icon {
        font-size: 1.2rem;
        flex-shrink: 0;
      }
      .banner-text {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2px;
      }
      .banner-title {
        font-family: Arial, Helvetica, sans-serif;
        font-weight: 600;
        font-size: clamp(1rem, 2.5vw, 1.3rem);
        letter-spacing: 3px;
        color: #facc15;
        line-height: 1;
      }
      .banner-sub {
        font-size: clamp(0.65rem, 1.5vw, 0.75rem);
        color: rgba(255, 255, 255, 0.45);
        letter-spacing: 1.5px;
        text-transform: uppercase;
        font-weight: 500;
      }
      .banner-countdown {
        display: flex;
        align-items: center;
        gap: 6px;
        background: rgba(2, 6, 23, 0.5);
        border: 1px solid rgba(250, 204, 21, 0.2);
        border-radius: 100px;
        padding: 5px 14px;
        font-family: 'Gill Sans', 'Gill Sans MT', Calibri, 'Trebuchet MS', sans-serif;
        font-weight: 600;
        font-size: clamp(0.9rem, 2vw, 1.1rem);
        letter-spacing: 3px;
        color: #fff;
        flex-shrink: 0;
      }
      .banner-countdown-label {
        font-family: "Outfit", sans-serif;
        font-size: 0.6rem;
        color: rgba(255, 255, 255, 0.4);
        letter-spacing: 1px;
        text-transform: uppercase;
        font-weight: 600;
      }

      /* ── VIDEO AREA ── */
      .video-area {
        flex: 1;
        position: relative;
        background: #000;
        min-height: 0;
      }

      .shaka-video-container {
        position: absolute;
        inset: 0;
        background: #000;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      video {
        width: 100%;
        height: 100%;
        object-fit: contain;
        background: #000;
      }

      /* SixStorm watermark — untouched logic */
      .custom-watermark {
        position: absolute;
        z-index: 40;
        pointer-events: none;
        top: 65%;
        left: 6%;
        transform: translateY(-50%);
        font-size: 11px;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.12);
      }

      /* ── BLOCK OVERLAY — logic untouched ── */
      .block-overlay {
        position: fixed;
        inset: 0;
        z-index: 99999;
        display: flex;
        align-items: center;
        justify-content: center;
        background: radial-gradient(circle at center, #0f172a 0%, #020617 100%);
        text-align: center;
      }
      .block-box {
        padding: 44px 40px;
        max-width: 480px;
        width: 90%;
        background: rgba(15, 23, 42, 0.96);
        border-radius: 20px;
        border: 1px solid rgba(250, 204, 21, 0.15);
        box-shadow:
          0 0 60px rgba(250, 204, 21, 0.06),
          0 30px 60px rgba(0, 0, 0, 0.6);
        animation: fadeInUp 0.55s ease-out;
      }
      @keyframes fadeInUp {
        from {
          opacity: 0;
          transform: translateY(28px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      .block-logo {
        font-family: "Bebas Neue", cursive;
        font-size: 1.6rem;
        letter-spacing: 2px;
        margin-bottom: 20px;
        display: flex;
        justify-content: center;
        gap: 1px;
      }
      .block-logo .six {
        background: linear-gradient(135deg, #facc15, #f97316);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }
      .block-title {
        font-family: "Bebas Neue", cursive;
        font-size: clamp(1.8rem, 6vw, 2.6rem);
        font-weight: 800;
        color: #ffffff;
        text-transform: uppercase;
        letter-spacing: 3px;
        margin-bottom: 14px;
        text-shadow: 0 0 20px rgba(239, 68, 68, 0.3);
      }
      .block-divider {
        width: 60px;
