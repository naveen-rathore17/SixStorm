      }
      .block-sub {
        font-size: clamp(0.8rem, 2vw, 0.9rem);
        font-weight: 500;
        color: rgba(255, 255, 255, 0.5);
        line-height: 1.7;
        letter-spacing: 0.5px;
      }
      .block-icon {
        display: none;
      }
      .block-note {
        display: none;
      }

      /* ── RESPONSIVE ── */
      @media (max-width: 640px) {
        .nav-channel {
          display: none;
        }
        #streamBanner {
          padding: 8px 14px;
          gap: 10px;
        }
        .banner-countdown {
          padding: 4px 10px;
        }
        .custom-watermark {
          font-size: 9px;
          top: 60%;
          left: 16%;
        }
        .block-box {
          padding: 28px 22px;
        }
        .block-title {
          font-size: 1.8rem;
        }
      }
    </style>
