<!DOCTYPE html>
<html lang="en">
  <head>
    <link rel="icon" type="image/png" href="/images/favicon.png" />
    <link rel="shortcut icon" href="/images/favicon.png" />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="SixStorm provides live cricket streaming access, match updates, and sports coverage from publicly available sources."
    />

    <meta
      name="keywords"
      content="cricket live, cricket streaming, live cricket match, IPL live, cricket watch online"
    />

    <meta name="author" content="Naveen Rathore" />

    <meta property="og:title" content="SixStorm Live Cricket Streaming" />

    <meta
      property="og:description"
      content="Watch live cricket matches and stay updated with match coverage."
    />

    <meta property="og:type" content="website" />

    <meta property="og:url" content="https://sixstorm.onrender.com" />
    <meta
      property="og:image"
      content="https://sixstorm.onrender.com/images/favicon.png"
    />

    <meta name="robots" content="index, follow" />

    <title>Privacy Policy | SixStorm</title>

    <script src="https://cdn.tailwindcss.com"></script>
  </head>

  <body
    class="bg-gradient-to-r from-gray-900 via-gray-800 to-gray-900 min-h-screen flex flex-col"
  >
    <!-- NAVBAR -->

    <nav
      class="bg-[#020617]/80 backdrop-blur-xl border-b border-white/10 sticky top-0 z-50"
    >
      <div
        class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center"
      >
        <a href="/" class="text-2xl md:text-3xl font-bold">
          <span
            class="bg-gradient-to-r from-yellow-400 to-orange-400 bg-clip-text text-transparent"
            >Six</span
          ><span class="text-white">Storm</span>
        </a>

        <button id="menuBtn" class="md:hidden text-white text-2xl">☰</button>

        <div
          id="menu"
          class="hidden md:flex md:items-center md:space-x-6 absolute md:static top-16 left-0 w-full md:w-auto bg-[#020617] md:bg-transparent text-center"
        >
          <a
            href="/"
            class="block py-3 md:py-0 text-gray-300 hover:text-yellow-400"
            >Home</a
          >
          <a
            href="/contact-us"
            class="block py-3 md:py-0 text-gray-300 hover:text-yellow-400"
            >Contact</a
          >
        </div>
      </div>
    </nav>

    <!-- MAIN CONTENT -->

    <main class="flex-grow px-4 py-10">
      <div
        class="max-w-3xl mx-auto bg-gray-900/60 backdrop-blur-md border border-white/10 rounded-2xl shadow-xl p-6 md:p-10"
      >
        <h1
          class="text-2xl md:text-3xl font-bold text-center mb-8 text-yellow-400"
        >
          Privacy Policy
        </h1>

        <p class="mb-6 text-gray-300 leading-relaxed">
          At <span class="font-semibold text-white">SixStorm</span>, we value
          your privacy. This Privacy Policy explains how we collect and use
          information when you visit our website.
        </p>

        <h2 class="text-lg md:text-xl font-semibold mt-6 mb-2 text-yellow-300">
          Information We Collect
        </h2>

        <p class="text-gray-300 mb-6 leading-relaxed">
          We do not collect personal information such as name, phone number, or
          address. However, basic non-personal data like browser type, device
          information, and pages visited may be collected automatically for
          analytics purposes.
        </p>

        <h2 class="text-lg md:text-xl font-semibold mt-6 mb-2 text-yellow-300">
          Cookies
        </h2>

        <p class="text-gray-300 mb-6 leading-relaxed">
          Our website may use cookies to improve user experience and understand
          how visitors interact with the site.
        </p>

        <h2 class="text-lg md:text-xl font-semibold mt-6 mb-2 text-yellow-300">
          Third-Party Content
        </h2>

        <p class="text-gray-300 mb-6 leading-relaxed">
          Some content displayed on SixStorm may come from external websites. We
          are not responsible for the privacy practices of those third-party
          sites.
        </p>

        <h2 class="text-lg md:text-xl font-semibold mt-6 mb-2 text-yellow-300">
          Changes to Policy
        </h2>

        <p class="text-gray-300 leading-relaxed">
          We may update this Privacy Policy from time to time. Any changes will
          be posted on this page.
        </p>
      </div>
    </main>

    <!-- FOOTER -->

    <footer
      class="bg-[#020617]/80 border-t border-white/10 text-center py-5 text-sm text-gray-300"
    >
      © 2026
      <span class="font-bold">
        <span
          class="bg-gradient-to-r from-yellow-400 to-orange-400 bg-clip-text text-transparent"
          >Six</span
        ><span class="text-white">Storm</span>
      </span>

      • Developed by Naveen Rathore
    </footer>

    <!-- MOBILE MENU SCRIPT -->

    <script>
      const btn = document.getElementById("menuBtn");
      const menu = document.getElementById("menu");

      btn.addEventListener("click", () => {
        menu.classList.toggle("hidden");
      });
    </script>
  </body>
</html>
